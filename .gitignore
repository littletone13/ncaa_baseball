!data/processed/.gitkeep
!data/processed/odds/.gitkeep
!data/registries/**

# Historical data we MUST keep
!data/raw/espn/
!data/raw/espn/games_2026.jsonl
!data/raw/ncaa/
!data/raw/ncaa/boxscores_2026.jsonl
!data/raw/ncaa/linescores_2026.jsonl
!data/raw/d1baseball/
!data/raw/d1baseball/*.tsv
!data/processed/games.csv
!data/processed/run_events.csv
!data/processed/pitcher_appearances.csv
!data/processed/pitcher_table.csv
!data/processed/team_table.csv
